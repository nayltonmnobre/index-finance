# GEMINI_API_KEY: Required for Gemini AI API calls.
# In Vercel, configure this exact name in Project Settings > Environment Variables.
# Keep it server-only: never add the VITE_ prefix and never commit a real key.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.5-flash"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Senha temporária de acesso enquanto não há autenticação no backend.
VITE_ACCESS_PASSWORD="troque-por-uma-senha-segura"
